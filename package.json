{
  "name": "solid_chat_adk",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "node --import tsx --watch-path=server.ts server.ts",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "tsx server.ts"
  },
  "dependencies": {
    "@google/adk": "^1.1.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.0",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "~5.7.3",
    "vite": "^6.0.11",
    "vite-plugin-solid": "^2.11.0"
  }
}
