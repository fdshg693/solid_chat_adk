{
  "name": "solid_chat_adk",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "node --import tsx --watch-path=server server/index.ts",
    "dev": "concurrently --kill-others \"vite\" \"node --import tsx --watch-path=server server/index.ts\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "tsx server/index.ts"
  },
  "dependencies": {
    "@google/adk": "^1.1.0",
    "@hono/node-server": "^2.0.4",
    "@tavily/core": "^0.7.3",
    "hono": "^4.12.23",
    "solid-js": "^1.9.12",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "~5.7.3",
    "vite": "^6.0.11",
    "vite-plugin-solid": "^2.11.0"
  }
}
